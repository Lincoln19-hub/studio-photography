generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime  @default(now())
  bookings  Booking[]
  invoices  Invoice[]

  @@map("clients")
}

model Booking {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service     String
  eventDate   DateTime
  duration    Int      // in hours
  location    String?
  budget      Float?
  notes       String?
  status      String   @default("pending") // pending, confirmed, completed, cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  invoice     Invoice?

  @@index([clientId])
  @@index([status])
  @@map("bookings")
}

model Invoice {
  id           String        @id @default(cuid())
  bookingId    String?       @unique
  booking      Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoiceNumber String       @unique
  amount       Float
  taxRate      Float         @default(0)
  taxAmount    Float         @default(0)
  total        Float
  status       String        @default("unpaid") // unpaid, paid, overdue, cancelled
  dueDate      DateTime
  paidDate     DateTime?
  paidAmount   Float?
  notes        String?
  items        InvoiceItem[]
  payments     Payment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int     @default(1)
  rate        Float
  amount      Float

  @@map("invoice_items")
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Float
  method      String   // cash, card, bank_transfer, mobile_money
  reference   String?
  date        DateTime @default(now())
  notes       String?

  @@index([invoiceId])
  @@map("payments")
}
